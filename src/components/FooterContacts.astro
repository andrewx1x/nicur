---
import Container from "./Container.astro";
import { site } from "../config/site";
---
<footer class="footer">
  <Container>
    <div class="footer-inner">
      <div class="footer-contacts">
        <h3>{site.contacts.title}</h3>
        <p>{site.contacts.city}</p>
        <p>{site.contacts.phone}</p>
        <p>{site.contacts.email}</p>
      </div>
      <div class="footer-credit">
        <a href="https://t.me/andrewqaz" target="_blank" rel="noopener noreferrer">Разработка сайта и контента</a>
      </div>
    </div>
    <p class="notice">{site.notice}</p>
  </Container>
</footer>
